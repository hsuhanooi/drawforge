{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": [
    "src/domain.ts",
    "src/card.js",
    "src/cards.js",
    "src/balance.js",
    "src/relics.js",
    "src/rewards.js",
    "src/events.js",
    "src/combat.js",
    "src/combatEngine.js",
    "src/deckZones.js",
    "src/energy.js",
    "src/combatState.js",
    "src/turns.js",
    "src/playCard.js"
  ]
}
